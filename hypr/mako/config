# === Основні налаштування ===
font=JetBrains Mono Nerd Font 10
width=300
height=100
margin=10
padding=15
border-size=1
border-radius=12
layer=overlay
anchor=bottom-left
output=DP-1

# === Анімації ===
default-timeout=5000
ignore-timeout=true

# === Стилі ===
background-color=#1E1E2E
text-color=#CDD6F4
border-color=#B4BEFE

[urgency=low]
background-color=#313244

[urgency=normal]
background-color=#1E1E2E

[urgency=high]
background-color=#F38BA8
text-color=#11111B
