{
  "layer": "top",
  "height": 32,
  "spacing": 4,
  "modules-left": ["custom/arch", "hyprland/workspaces", "custom/media"],
  "modules-center": ["clock", "custom/date"],
  "modules-right": [
    "bluetooth",
    "power-profiles-daemon",
    "pulseaudio",
    "pulseaudio#microphone",
    "network",
    "battery",
    "custom/language",
    "custom/power"
  ],

  "hyprland/workspaces": {
    "format": "{icon}",
    "on-click": "activate",
    "format-icons": {
      "1": "I",
      "2": "II",
      "3": "III",
      "4": "IV",
      "5": "V",
      "6": "VI",
      "7": "VII",
      "8": "VIII",
      "9": "IX",
      "10": "X",
      "urgent": "!",
      "focused": "β•Ε",
      "default": "¬Ζ"
    },
    "persistent-workspaces": {
      "1": [], "2": [], "3": [], "4": [], "5": []
    },
    "all-outputs": true,
    "sort-by-number": true
  },

  "clock": {
    "format": " {:%H:%M}",
    "tooltip-format": "{:%A, %d %B %Y}",
    "tooltip": false,
    "interval": 1
  },

  "custom/date": {
    "format": "|  {}",
    "exec": "date +'%a %d.%m.%y'",
    "tooltip": false,
    "interval": 30
  },

  "custom/language": {
    "exec": "~/.config/waybar/get_lang.sh",
    "interval": 1,
    "format": "{}",
    "tooltip": false
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{capacity}% {icon}",
    "format-icons": ["σΑ²é", "σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ¹Ι"],
    "format-charging": "σΑ²³ {capacity}%",
    "format-plugged": "σΑ²³ {capacity}%",
    "tooltip-format": "{capacity}% remaining"
  },

  "network": {
    "format-wifi": "{icon}  {essid}",
    "format-icons": ["σΑΛ·", "σΑΛü", "σΑΛΔ", "σΑΛΞ", "σΑΛ®"],
    "format-ethernet": "σΑÄ²   {ifname}",
    "format-alt": "σ±¦΅",
    "format-disconnected": "σΑ•Σ",
    "tooltip-format-wifi": "β΅Θ  {bandwidthDownBytes}  β΅Γ  {bandwidthUpBytes}",
    "tooltip-format-ethernet": "β΅Θ  {bandwidthDownBytes}  β΅Γ  {bandwidthUpBytes}",
    "interval": 5
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "σΑ•¹",
    "format-icons": {
      "default": ["σΑïΩ", "σΑ•Ä", "σΑïΨ"]
    },
    "on-click": "pamixer -t"
  },

  "pulseaudio#microphone": {
    "format": "{format_source}",
    "format-source": "σΑç§ {volume}%",
    "format-source-muted": "σΑç≠",
    "on-click": "pamixer --default-source -t",
    "scroll-step": 1,
    "on-click-right": "pavucontrol"
  },

  "power-profiles-daemon": {
    "format": "{icon}",
    "format-icons": {
      "power-saver": "σΑΨÜ",
      "balanced": "σΑΨÖ",
      "performance": "σΑ™Ö"
    },
    "tooltip-format": "Power: {profile}"
  },

  "bluetooth": {
    "format": "σΑ²·",
    "format-disabled": "σΑ²≤",
    "format-connected": "σΑ²±",
    "on-click": "blueman-manager"
  },

  "custom/arch": {
    "format": "σΑΘ΅",
    "on-click": "wofi --show drun"
  },

  "custom/media": {
    "exec": "playerctl -p spotify,firefox,chromium metadata --format '{\"text\": \"{{artist}} - {{title}}\", \"status\": \"{{status}}\"}'",
    "interval": 1,
    "format": "οÄ¹   <span>{text}</span>",
    "return-type": "json",
    "max-length": 40,
    "on-click": "playerctl play-pause",
    "on-click-right": "playerctl next",
    "tooltip": true,
    "escape": true
  },

  "custom/power": {
    "format": "σΑêΞ",
    "on-click": "/home/artur/.config/wofi/powermenu.sh"
  }
}
