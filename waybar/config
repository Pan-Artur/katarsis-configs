{
  "layer": "top",
  "height": 32,
  "spacing": 4,
  "modules-left": ["custom/arch", "hyprland/workspaces", "custom/media"],
  "modules-center": ["clock", "custom/date"],
  "modules-right": [
    "bluetooth",
    "power-profiles-daemon",
    "pulseaudio",
    "pulseaudio#microphone",
    "network",
    "battery",
    "custom/language",
    "custom/power"
  ],

  "hyprland/workspaces": {
    "format": "{icon}",
    "on-click": "activate",
    "format-icons": {
      "1": "I",
      "2": "II",
      "3": "III",
      "4": "IV",
      "5": "V",
      "6": "VI",
      "7": "VII",
      "8": "VIII",
      "9": "IX",
      "10": "X",
      "urgent": "!",
      "focused": "โถ",
      "default": "ยท"
    },
    "persistent-workspaces": {
      "1": [], "2": [], "3": [], "4": [], "5": []
    },
    "all-outputs": true,
    "sort-by-number": true
  },

  "clock": {
    "format": " {:%H:%M}",
    "tooltip-format": "{:%A, %d %B %Y}",
    "tooltip": false,
    "interval": 1
  },

  "custom/date": {
    "format": "|  {}",
    "exec": "date +'%a %d.%m.%y'",
    "tooltip": false,
    "interval": 30
  },

  "custom/language": {
    "exec": "~/.config/waybar/get_lang.sh",
    "interval": 1,
    "format": "{}",
    "tooltip": false
  },

  "battery": {
    "states": {
