### APPEARANCE ###
font=JetBrainsMono Nerd Font 11
width=320
height=150
padding=15
border-size=2
border-radius=10

### POSITIONING ###
anchor=bottom-left
outer-margin=0, 15, 25, 15
layer=overlay

### COLORS (Deep Night Palette) ###
background-color=#050a15
text-color=#e2e8f0
border-color=#1e3a8a
progress-color=over #1e40af

### BEHAVIOR ###
max-history=5
sort=-time
default-timeout=5000
ignore-timeout=1

### URGENCY LEVELS ###
[urgency=high]
border-color=#ef4444
default-timeout=0
